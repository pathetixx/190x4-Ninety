{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ninety",
  "version": "0.1.30",
  "identifier": "pw.x190x4.ninety",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Ninety",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/sing-box", "binaries/ninety-tunnel-svc"],
    "resources": {
      "binaries/wintun.dll": "wintun.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "./windows/hooks.nsh",
        "headerImage": "./windows/header.bmp",
        "sidebarImage": "./windows/sidebar.bmp",
        "license": "./windows/license.txt",
        "displayLanguageSelector": false,
        "languages": ["English", "Russian"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ninety"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1N0I1RTAwMEQ3MUQ3OUUKUldTZTEzRU5BRjU3ZGN3TkZoK28yeFRVa2tLdlhxNy8zUXo1aUdXN1lOSUE3MzZLUmVCRnFYamsK",
      "endpoints": [
        "https://github.com/pathetixx/190x4-Ninety/releases/latest/download/latest.json"
      ]
    }
  }
}
